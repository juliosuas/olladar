#!/usr/bin/env python3
"""olladar-stream — send a prompt to ollama (via olladar proxy) and display
tokens streaming live with a rolling tok/s counter."""

import argparse, json, sys, time, urllib.request, urllib.error
import os, select, signal

RESET = "\033[0m"
DIM = "\033[2m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
BOLD = "\033[1m"

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("prompt", nargs="*", help="Prompt (or read stdin if empty)")
    ap.add_argument("--model", default="qwen3:32b")
    ap.add_argument("--endpoint", default="http://127.0.0.1:11435",
                    help="ollama-compat endpoint (default: olladar proxy)")
    ap.add_argument("--think", choices=["on","off","default"], default="default",
                    help="override think flag (default: proxy decides)")
    ap.add_argument("--max-tokens", type=int, default=1000)
    ap.add_argument("--temp", type=float, default=0.4)
    ap.add_argument("--keep-alive", default="24h")
    ap.add_argument("--tools", action="store_true",
                    help="include a dummy tools[] to trigger the proxy's think:false path")
    args = ap.parse_args()

    prompt = " ".join(args.prompt).strip() or sys.stdin.read().strip()
    if not prompt:
        ap.error("need prompt")

    body = {
        "model": args.model,
        "messages": [{"role": "user", "content": prompt}],
        "stream": True,
        "keep_alive": args.keep_alive,
        "options": {"num_predict": args.max_tokens, "temperature": args.temp},
    }
    if args.think != "default":
        body["think"] = (args.think == "on")
    if args.tools:
        body["tools"] = [{"type":"function","function":{
            "name":"shell_run","description":"Run bash",
            "parameters":{"type":"object","properties":{"cmd":{"type":"string"}},"required":["cmd"]}
        }}]

    req = urllib.request.Request(
        f"{args.endpoint}/api/chat",
        data=json.dumps(body).encode(),
        headers={"Content-Type": "application/json"},
    )

    print(f"{DIM}endpoint={args.endpoint}  model={args.model}  think={args.think}  tools={args.tools}{RESET}")
    print(f"{BOLD}>>> {prompt[:120]}{RESET}\n")

    t_start = time.time()
    t_first_tok = None
    total_tok = 0
    eval_count = 0
    prompt_eval_count = 0
    total_duration = 0

    try:
        resp = urllib.request.urlopen(req, timeout=300)
    except urllib.error.URLError as e:
        print(f"\n{YELLOW}ERROR: {e}{RESET}")
        sys.exit(1)

    last_ui_tick = 0
    def print_status(final=False):
        nonlocal last_ui_tick
        now = time.time()
        if not final and now - last_ui_tick < 0.1:
            return
        last_ui_tick = now
        if t_first_tok:
            gen_secs = now - t_first_tok
            tps = total_tok / gen_secs if gen_secs > 0.3 else 0  # wait 300ms before trusting
            ttft = (t_first_tok - t_start) * 1000
            # status line at bottom (stderr so stdout stream isn't disturbed)
            sys.stderr.write(f"\r{DIM}[ttft={ttft:5.0f}ms  tok={total_tok:4d}  {CYAN}{tps:5.1f} tok/s{DIM}  wall={now-t_start:5.1f}s]{RESET}")
            sys.stderr.flush()

    last_content = ""
    in_thinking = False
    try:
        for line in resp:
            try:
                d = json.loads(line.decode())
            except:
                continue
            msg = d.get("message", {})
            # streaming deltas: message.content (or thinking), then final chunk has metrics
            content = msg.get("content") or ""
            thinking = msg.get("thinking") or ""
            if thinking and isinstance(thinking, str):
                if not in_thinking:
                    sys.stdout.write(f"{DIM}<think>{RESET}")
                    in_thinking = True
                sys.stdout.write(f"{DIM}{thinking}{RESET}")
                sys.stdout.flush()
                # rough token estimate (~4 chars/token)
                total_tok += max(1, len(thinking) // 3)  # ~3 chars/token (qwen3 tokenizer)
                if t_first_tok is None:
                    t_first_tok = time.time()
            if content and isinstance(content, str):
                if in_thinking:
                    sys.stdout.write(f"{DIM}</think>{RESET}\n")
                    in_thinking = False
                sys.stdout.write(content)
                sys.stdout.flush()
                total_tok += max(1, len(content) // 3)  # ~3 chars/token (qwen3 tokenizer)
                if t_first_tok is None:
                    t_first_tok = time.time()
            if msg.get("tool_calls"):
                sys.stdout.write(f"\n{GREEN}[tool_call] {json.dumps(msg['tool_calls'])}{RESET}\n")
            if d.get("done"):
                eval_count = d.get("eval_count", total_tok)
                prompt_eval_count = d.get("prompt_eval_count", 0)
                total_duration = d.get("total_duration", 0)
                eval_duration = d.get("eval_duration", 0)
                real_tps = eval_count * 1e9 / eval_duration if eval_duration else 0
                sys.stderr.write("\n")
                sys.stderr.write(
                    f"\n{BOLD}done{RESET} "
                    f"{DIM}prompt_tok={prompt_eval_count}  eval_tok={eval_count}  "
                    f"{CYAN}{real_tps:.1f} tok/s{RESET}  "
                    f"{DIM}total={total_duration/1e9:.2f}s{RESET}\n"
                )
                break
            print_status()
    except KeyboardInterrupt:
        sys.stderr.write(f"\n{YELLOW}[interrupted]{RESET}\n")
    finally:
        print_status(final=True)

if __name__ == "__main__":
    main()
